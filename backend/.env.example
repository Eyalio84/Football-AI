# Soccer-AI Backend Environment Variables
# Copy this to .env and fill in your keys

# Required: Anthropic API key for Haiku 4.5 chat
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required: football-data.org API key (free tier: 10 req/min)
# Register at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-key-here

# Optional: Daily budget cap for AI calls (in USD, default $5)
DAILY_BUDGET_CAP=5.0

# Optional: Additional CORS origins (comma-separated)
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com
